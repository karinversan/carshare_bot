APP_ENV=dev
DEBUG=true

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/car_inspection
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/car_inspection
REDIS_URL=redis://redis:6379/0

S3_ENDPOINT_URL=http://minio:9000
S3_EXTERNAL_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_SECURE=false

S3_BUCKET_RAW_IMAGES=raw-images
S3_BUCKET_PROCESSED_IMAGES=processed-images
S3_BUCKET_OVERLAYS=overlays
S3_BUCKET_CLOSEUPS=closeups
S3_BUCKET_REPORTS=reports
S3_BUCKET_ML_ARTIFACTS=ml-artifacts

API_BASE_URL=http://api-service:8000
PUBLIC_API_BASE_URL=http://localhost:8000

BOT_SERVICE_BASE_URL=http://bot-service:8001
PUBLIC_WEBHOOK_URL=http://localhost:8001

MINIAPP_BASE_URL=http://localhost:5173
ADMIN_PANEL_URL=http://localhost:5174/admin
PUBLIC_WEB_BASE_URL=http://localhost:5173
# Frontend dev proxy target for Vite (/api -> backend).
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000
TELEGRAM_POLLING_ENABLED=false

TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_SECRET=replace-me

JWT_SECRET=supersecret
AUTH_ENABLED=false
ADMIN_DEMO_EMAIL=admin@example.com
ADMIN_DEMO_PASSWORD=admin123

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

INFERENCE_SERVICE_URL=http://inference-service:8010
INFERENCE_BACKEND=weights
REQUIRE_REAL_INFERENCE=true
# Temporary debugging switch:
# true  -> do not reject by viewpoint mismatch (accepts side/front/rear angle mix)
# false -> full viewpoint validation enabled
QUALITY_VIEW_DISABLE_VIEWPOINT_CHECK=false

MLFLOW_TRACKING_URI=http://mlflow:5000
QUALITY_VIEW_MODEL_NAME=quality_view
QUALITY_VIEW_MODEL_ALIAS=champion
DAMAGE_SEG_MODEL_NAME=damage_seg
DAMAGE_SEG_MODEL_ALIAS=champion
# Optional explicit path to a local YOLO segmentation checkpoint.
# If empty, inference-service falls back to repo weights / latest discovered run.
# Recommended future usage: point this to a Hugging Face-downloaded .pt file.
# Existing repo weights can stay in place as archive/fallback and do not need to be deleted.
DAMAGE_SEG_WEIGHTS_PATH=
# Optional metadata.json for custom weights. Leave empty to infer classes from the checkpoint itself.
DAMAGE_SEG_METADATA_PATH=
DAMAGE_SEG_INFERENCE_IMGSZ=640
DAMAGE_SEG_CONFIDENCE_THRESHOLD=0.25
DAMAGE_SEG_POST_FILTER_CONFIDENCE=0.45
DAMAGE_SEG_MIN_AREA_NORM=0.003
DAMAGE_SEG_MAX_AREA_NORM=0.35
DAMAGE_AUTO_CONFIRM_CONFIDENCE=0.70
DAMAGE_AUTO_UNCERTAIN_CONFIDENCE=0.45

WANDB_MODE=disabled
